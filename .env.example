APP_ENV=development
LOG_LEVEL=INFO

DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=123456789012345678
DISCORD_ADMIN_ROLE_IDS=111111111111111111,222222222222222222
DISCORD_UPLOADER_ROLE_IDS=333333333333333333
DISCORD_VIEWER_ROLE_IDS=444444444444444444
ALLOWED_CHANNEL_IDS=555555555555555555,666666666666666666

GOOGLE_SERVICE_ACCOUNT_FILE=./secrets/google-service-account.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_drive_root_folder_id_here
GOOGLE_DRIVE_SHARED_DRIVE_ID=
GOOGLE_DRIVE_USE_SHARED_DRIVE=true

DATABASE_URL=sqlite:///./bot.db

MAX_UPLOAD_MB=25
ALLOWED_EXTENSIONS=pdf,docx,xlsx,pptx,txt,png,jpg,jpeg
DATE_FORMAT=%Y%m%d
