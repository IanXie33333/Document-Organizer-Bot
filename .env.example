APP_ENV=development
LOG_LEVEL=INFO
TIMEZONE=UTC

DISCORD_BOT_TOKEN=YOUR_NEW_ROTATED_TOKEN
DISCORD_GUILD_ID=123456789012345678
DISCORD_ADMIN_ROLE_IDS=1487744861162573865
DISCORD_UPLOADER_ROLE_IDS=1487746052063756419
DISCORD_VIEWER_ROLE_IDS=333333333333333333
ALLOWED_CHANNEL_IDS=1479314479488696403

GOOGLE_SERVICE_ACCOUNT_FILE=./secrets/google-service-account.json
GOOGLE_AUTH_MODE=service_account
GOOGLE_OAUTH_CLIENT_SECRETS_FILE=./secrets/google-oauth-client.json
GOOGLE_OAUTH_TOKEN_FILE=./secrets/google-oauth-token.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_drive_root_folder_id_here

GOOGLE_DRIVE_SHARED_DRIVE_ID=
GOOGLE_DRIVE_USE_SHARED_DRIVE=true

DATABASE_URL=sqlite:///./bot.db
MAX_UPLOAD_MB=25
ALLOWED_EXTENSIONS=pdf,docx,xlsx,pptx,txt,png,jpg,jpeg
DATE_FORMAT=%Y%m%d
FILE_NAME_TEMPLATE={project}_{category}_{date}_{title}_v{version}
